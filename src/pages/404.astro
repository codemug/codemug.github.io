---
import Base from "../layouts/Base.astro";

const title = "404 · Usman Shahid";
const description = "Page not found.";
---

<Base title={title} description={description} path="/404">
  <section
    class="max-w-[980px] mx-auto px-6 sm:px-8 py-28 sm:py-36 text-center"
  >
    <p
      class="font-mono text-[13px] uppercase tracking-[0.16em] text-[--color-accent] mb-4"
    >
      404
    </p>
    <h1
      class="text-[clamp(36px,6vw,56px)] font-semibold tracking-[-0.03em] text-[--color-text] mb-5"
    >
      Page not found.
    </h1>
    <p class="text-[17px] text-[--color-text-muted] mb-9 max-w-[480px] mx-auto leading-relaxed">
      That page doesn't exist (yet). Head back home or get in touch.
    </p>
    <div class="flex flex-wrap gap-3.5 justify-center">
      <a href="/" class="btn btn-primary">
        Back home
        <span class="text-base">→</span>
      </a>
      <a href="/#contact" class="btn btn-ghost">Get in touch</a>
    </div>
  </section>
</Base>
