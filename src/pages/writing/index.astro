---
import Base from "../../layouts/Base.astro";
import SectionHeading from "../../components/SectionHeading.astro";

const title = "Writing · Usman Shahid";
const description =
  "Technical writing by Usman Shahid — MCP, tool-calling, Kubernetes, Keycloak access control, and the agentic-AI era of SRE.";

const articles = [
  {
    date: "2025-10",
    title: "Enabling MCP on Your Existing Microservices",
    series: "LLM Tool Calling Series · Part 2",
    href: "https://usmanshahid.medium.com/llm-tool-calling-series-part-2-enabling-mcp-on-your-existing-microservices-bfc9ce7dc67f",
    note: "Practical deep-dive on retrofitting existing microservices to expose MCP endpoints — drawn from the production AI Agent Platform at Careem (~200K req/day, ~800 tools, ~60 agents).",
  },
  {
    date: "2025-06",
    title: "Understanding Tool Calling and the Model Context Protocol (MCP)",
    series: "LLM Tool Calling Series · Part 1",
    href: "https://usmanshahid.medium.com/llm-tool-calling-series-part-1-understanding-tool-calling-and-the-model-context-protocol-mcp-911a7c422fd8",
    note: "A primer on what MCP is and why tool-calling matters for production LLM systems — published before MCP became mainstream.",
  },
  {
    date: "2020-08",
    title: "Keycloak Access Control Series",
    series: "4 parts · OIDC, RBAC, K8s integration",
    href: "https://medium.com/@usmanshahid",
    note: "Token authentication, authentication flows, role-based access control, and Kubernetes integration. Backs the ArgoCD + Keycloak GitOps work at Intech.",
  },
];
---

<Base title={title} description={description} path="/writing/">
  <section class="max-w-[980px] mx-auto px-6 sm:px-8 py-16 sm:py-20">
    <SectionHeading eyebrow="Writing" title="Technical writing" />
    <p class="text-[--color-text-soft] leading-relaxed mb-12 max-w-[680px] text-[17px]">
      I write on Medium about the systems I ship: tool-calling and the Model
      Context Protocol, gateway and Kubernetes work, and access control. The
      pieces below are the ones worth reading first.
    </p>
    <div class="flex flex-col">
      {
        articles.map((a) => (
          <a
            href={a.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group grid grid-cols-[1fr_auto] gap-6 items-start py-7 border-t border-[--color-hairline] transition-[padding] duration-200 hover:pl-3"
          >
            <div>
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
                <span class="font-mono text-[12px] text-[--color-text-dim]">
                  {a.date}
                </span>
                <span class="font-mono text-[12px] text-[--color-accent]">
                  {a.series}
                </span>
              </div>
              <h3 class="text-[19px] font-medium tracking-[-0.01em] leading-snug text-[--color-text] mb-2 max-w-[680px]">
                {a.title}
              </h3>
              <p class="text-[14.5px] text-[--color-text-muted] leading-relaxed max-w-[680px]">
                {a.note}
              </p>
            </div>
            <span
              class="text-[22px] text-[--color-text-dim] transition-all duration-200 group-hover:text-[--color-accent] group-hover:translate-x-1"
              aria-hidden="true"
            >
              ↗
            </span>
          </a>
        ))
      }
    </div>
    <p class="mt-10 text-[14px] text-[--color-text-muted]">
      Full archive on <a
        href="https://medium.com/@usmanshahid"
        target="_blank"
        rel="noopener noreferrer">medium.com/@usmanshahid</a
      >.
    </p>
  </section>
</Base>
