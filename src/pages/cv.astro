---
import Base from "../layouts/Base.astro";

const title = "CV · Usman Shahid";
const description =
  "Full CV of Usman Shahid — Staff Site Reliability Engineer at Careem. 11+ years scaling cloud infrastructure. Download as PDF.";

const jobs = [
  {
    role: "Staff Site Reliability Engineer · Careem",
    period: "Jan 2023 — Present",
    summary:
      "Technical Lead and SRE Architect mentoring a team focused on infrastructure provisioning and developer experience.",
    points: [
      'Designed and built a <strong class="text-[--color-text]">self-service AI Agent Platform</strong> with MCP tool-calling, multi-agent orchestration, and HITL approval flows for internal infrastructure-support workflows — ~200K req/day, ~800 registered tools, ~60 agents in production. Engineering teams contribute their own tools and agents.',
      '<strong class="text-[--color-text]">Slashed EKS cluster costs by 40%</strong> via resource-optimization program — Karpenter consolidation, migration to ARM &amp; Spot nodes, VPA, and custom scheduling (FinOps at scale).',
      'Consolidated <strong class="text-[--color-text]">12 legacy API gateways (~10k RPS) onto a single Kong gateway with 99.99% uptime</strong> during cutover; built a GitOps-driven bespoke control plane for API route management.',
      "Designed and deployed a fully automated cloud-resource provisioning platform with GitOps (Terraform + Terragrunt) — provisioning time for new services from days to minutes.",
    ],
  },
  {
    role: "Senior Site Reliability Engineer · Careem",
    period: "Dec 2020 — Jan 2023",
    summary: "Led migration of 300+ microservices from legacy AWS to AWS EKS.",
    points: [
      "Engineered automated provisioning of multiple EKS clusters with Terraform + Terragrunt — repeatable, auditable infrastructure foundation.",
      "Provisioned centralized API Gateways using Kong with a GitOps control plane for API route management.",
      'Built the observability stack with <strong class="text-[--color-text]">Prometheus, Thanos, and Grafana</strong> — high-cardinality metric storage, SLO dashboards, cost tracking across the EKS fleet.',
      "Improved deployment velocity and safety via service mesh (Linkerd) with automated canary rollouts via Flagger.",
      "On-call 24×7 on a bi-weekly rotation for the cloud-infrastructure platform.",
    ],
  },
  {
    role: "Infrastructure Architect & Team Lead · Intech IIS",
    period: "Jul 2019 — Dec 2020",
    summary: null,
    points: [
      "Designed and implemented the infrastructure of a Cloud IIoT Platform while leading a team of 6 polyglot engineers in a KanBan model — workload distribution, technology selection, mentoring, customer integration.",
      'Built a bespoke <strong class="text-[--color-text]">Kubernetes Ingress Operator</strong> for bare-metal Kubernetes clusters using RedHat operator-sdk (custom control-plane work, not just operator consumption).',
      'Secured &amp; streamlined the software delivery lifecycle by integrating <strong class="text-[--color-text]">ArgoCD with Keycloak</strong> — a secure, auditable GitOps workflow for Helm-based deployments.',
      "Implemented Google SRE golden signals (latency / traffic / errors / saturation) on bare-metal Kubernetes clusters using Prometheus.",
    ],
  },
  {
    role: "Senior Software Developer / DevOps Engineer · Intech IIS",
    period: "Jan 2017 — Jun 2019",
    summary: null,
    points: [
      "Containerized all services of a distributed Industrial IoT platform with Docker; orchestrated via Kubernetes and D2iQ stacks.",
      "Automated deployment of the IIoT platform using Ansible Playbooks; provisioned production-ready Kubernetes and D2iQ clusters.",
      "Built a serverless framework in Python running code on containers via Kubernetes / Marathon / Metronome.",
      "Built a parallel metric aggregation publisher for StatsD in Golang.",
      "Built an OPC → MQTT data pipeline service in C# using Avro RPC and REST.",
      "Built a generic client API using Java Streams for CRUD operations on IBM Maximo and SAP EAM systems via Avro schemas, exposed via Avro RPC.",
      "Built an OpenID Connect Identity Provider microservice using Spring OAuth2 with JDBC, Active Directory, LDAP, and Mongo storage backends (Spring JPA + Spring LDAP).",
      "Implemented dynamic proxying and JWT bearer authentication using OpenResty LuaJIT.",
    ],
  },
  {
    role: "Software Developer · Diyatech (Alachisoft)",
    period: "Jun 2014 — Jan 2017",
    summary:
      'Core developer for <strong class="text-[--color-text]">NCache Enterprise</strong> (Redis-class distributed cache for .NET) and <strong class="text-[--color-text]">NosDB Enterprise</strong> (CouchDB/MongoDB-class NoSQL JSON store for .NET), both in C#.',
    points: [
      "Reimplemented Microsoft's Collections to prevent Large Object Heap (LOH) leakage.",
      "Implemented the ASP.NET Core Session State Management middleware with NCache backend storage and full session-locking support.",
      "Implemented a reliable socket protocol for message delivery using Protobuf.",
      "Built file-storage-based B+ Tree indexing with support for single-attribute and compound indexes.",
      "Built the query execution system using Streams and nested Enumerables in C#.",
    ],
  },
];

const skills = [
  {
    cat: "Site Reliability / Platform",
    detail:
      "SRE practices, SLO/SLI/error budgets, on-call & incident response, GitOps, Internal Developer Platforms, FinOps, capacity planning",
  },
  {
    cat: "Kubernetes ecosystem",
    detail:
      "Kubernetes (managed + bare-metal), Karpenter, VPA, custom scheduling, Linkerd, Flagger, Helm, Kustomize, ArgoCD, operator-sdk (custom Go operators)",
  },
  {
    cat: "Cloud",
    detail:
      "AWS (EKS, EC2, S3, VPC, Route 53, IAM), bare-metal Kubernetes, multi-cluster patterns",
  },
  {
    cat: "Observability",
    detail:
      "Prometheus, Thanos, Grafana, Google SRE golden signals, SLO dashboards",
  },
  {
    cat: "Infrastructure & CI/CD",
    detail: "Terraform, Terragrunt, Ansible, Docker, D2iQ, GitLab CI",
  },
  {
    cat: "API & Gateway",
    detail:
      "Kong (12→1 consolidation, ~10k RPS, 99.99% uptime), OpenResty / LuaJIT, OpenID Connect, JWT, dynamic proxying",
  },
  {
    cat: "AI / LLMOps",
    detail:
      "Model Context Protocol (MCP), multi-agent orchestration, HITL approval flows, AI Agent Platform engineering; daily use of Claude, Cursor, GitHub Copilot, Gemini",
  },
  {
    cat: "Languages",
    detail:
      "Go (production), Python (production), Java (production), C# / .NET (production)",
  },
  {
    cat: "Data / Storage internals",
    detail:
      "B+ Tree indexing (NosDB), distributed-cache internals (NCache), Mongo, LDAP, JDBC, Avro / Protobuf",
  },
];
---

<Base title={title} description={description} path="/cv/">
  <article class="max-w-[980px] mx-auto px-6 sm:px-8 py-16 sm:py-20">
    <header class="mb-12 pb-10 border-b border-[--color-hairline]">
      <p class="font-mono text-[13px] uppercase tracking-[0.16em] text-[--color-accent] mb-4">
        Curriculum Vitae
      </p>
      <h1
        class="text-[clamp(36px,6vw,56px)] font-semibold tracking-[-0.03em] text-[--color-text] mb-4"
      >
        Usman Shahid
      </h1>
      <p class="text-[--color-text-muted] mb-1 text-[15px]">
        <a href="mailto:u.manshahid@gmail.com">u.manshahid@gmail.com</a> ·
        +971-52-932-8265 ·
        <a
          href="https://github.com/codemug"
          target="_blank"
          rel="noopener noreferrer">github.com/codemug</a
        > ·
        <a
          href="https://linkedin.com/in/u-manshahid"
          target="_blank"
          rel="noopener noreferrer">linkedin.com/in/u-manshahid</a
        >
      </p>
      <p class="text-sm text-[--color-text-muted] mb-7">
        Open to relocation: EU / UK / Ireland / Netherlands / Germany — visa
        sponsorship required. Currently Dubai (GMT+4).
      </p>
      <a href="/cv-usman-shahid.pdf" class="btn btn-primary">Download PDF</a>
    </header>

    <section class="mb-14">
      <h2 class="font-mono text-[12.5px] uppercase tracking-[0.1em] text-[--color-text-dim] mb-5">
        Summary
      </h2>
      <p class="text-[--color-text-soft] leading-relaxed text-[15px]">
        Staff <strong class="text-[--color-text]"
          >Site Reliability Engineer</strong
        > and Technical Lead with <strong class="text-[--color-text]"
          >11+ years</strong
        > scaling resilient, cost-effective cloud infrastructure for
        high-traffic services. Currently running a self-service AI Agent
        Platform with Model Context Protocol (MCP) tool-calling, multi-agent
        orchestration, and human-in-the-loop (HITL) approval flows —
        <strong class="text-[--color-text]">~200K requests/day</strong>,
        <strong class="text-[--color-text]">~800 registered tools</strong>,
        <strong class="text-[--color-text]">~60 production agents</strong>
        — bridging classic SRE discipline with the agentic-AI era. Track record:
        <strong class="text-[--color-text]">40% EKS cost reduction</strong>
        via Karpenter / ARM / Spot / VPA, <strong class="text-[--color-text]"
          >99.99% uptime</strong
        > consolidating 12 API gateways to Kong at ~10k RPS, <strong
          class="text-[--color-text]">300+ microservices</strong
        > migrated to EKS. Polyglot — production Go, Python, Java, and C#. Daily
        AI-tooling user (Claude, Cursor, Copilot, Gemini).
      </p>
    </section>

    <section class="mb-14">
      <h2 class="font-mono text-[12.5px] uppercase tracking-[0.1em] text-[--color-text-dim] mb-5">
        Work Experience
      </h2>
      <div class="flex flex-col">
        {
          jobs.map((j) => (
            <div class="grid grid-cols-1 sm:grid-cols-[172px_1fr] gap-2 sm:gap-9 py-7 border-t border-[--color-hairline]">
              <div class="font-mono text-[12.5px] tracking-[0.02em] text-[--color-text-dim] sm:pt-1">
                {j.period}
              </div>
              <div>
                <h3 class="text-[18px] font-semibold tracking-[-0.01em] text-[--color-text] mb-2">
                  {j.role}
                </h3>
                {j.summary && (
                  <p
                    class="text-[14.5px] text-[--color-text-muted] mb-3 max-w-[640px]"
                    set:html={j.summary}
                  />
                )}
                <ul class="flex flex-col gap-2.5 list-none">
                  {j.points.map((p) => (
                    <li class="flex gap-3 text-[14.5px] leading-snug text-[--color-text-soft] max-w-[660px]">
                      <span class="flex-none mt-[7px] w-[5px] h-[5px] rounded-full bg-[--color-accent]" />
                      <span set:html={p} />
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mb-14">
      <h2 class="font-mono text-[12.5px] uppercase tracking-[0.1em] text-[--color-text-dim] mb-5">
        Skills
      </h2>
      <dl class="flex flex-col">
        {
          skills.map((s) => (
            <div class="grid grid-cols-1 sm:grid-cols-[172px_1fr] gap-1 sm:gap-9 py-4 border-t border-[--color-hairline]">
              <dt class="font-semibold text-[--color-text] text-[14.5px]">
                {s.cat}
              </dt>
              <dd class="text-[14.5px] leading-relaxed text-[--color-text-muted] max-w-[660px]">
                {s.detail}
              </dd>
            </div>
          ))
        }
      </dl>
    </section>

    <section class="mb-14">
      <h2 class="font-mono text-[12.5px] uppercase tracking-[0.1em] text-[--color-text-dim] mb-5">
        Selected Writing
      </h2>
      <ul class="flex flex-col gap-3 text-[--color-text-soft] text-[14.5px] leading-relaxed list-disc pl-5 marker:text-[--color-text-dim]">
        <li>
          <strong class="text-[--color-text]"
            >LLM Tool Calling Series · Part 2</strong
          > —
          <a
            href="https://usmanshahid.medium.com/llm-tool-calling-series-part-2-enabling-mcp-on-your-existing-microservices-bfc9ce7dc67f"
            target="_blank"
            rel="noopener noreferrer"
            >Enabling MCP on Your Existing Microservices</a
          > · Medium, October 2025
        </li>
        <li>
          <strong class="text-[--color-text]"
            >LLM Tool Calling Series · Part 1</strong
          > —
          <a
            href="https://usmanshahid.medium.com/llm-tool-calling-series-part-1-understanding-tool-calling-and-the-model-context-protocol-mcp-911a7c422fd8"
            target="_blank"
            rel="noopener noreferrer"
            >Understanding Tool Calling and the Model Context Protocol (MCP)</a
          > · Medium, June 2025 <em class="text-[--color-text-dim]"
            >(published before MCP became mainstream)</em
          >
        </li>
        <li>
          <strong class="text-[--color-text]">Keycloak Access Control Series</strong
          > (4 parts, August 2020) — token authentication, authentication flows,
          role-based access control, and Kubernetes integration. <a
            href="https://medium.com/@usmanshahid"
            target="_blank"
            rel="noopener noreferrer">Series index on Medium</a
          >
        </li>
      </ul>
    </section>

    <section class="mb-14">
      <h2 class="font-mono text-[12.5px] uppercase tracking-[0.1em] text-[--color-text-dim] mb-5">
        Awards
      </h2>
      <p class="text-[--color-text-soft] text-[14.5px]">
        <strong class="text-[--color-text]">Excellence Award</strong>,
        Alachisoft Inc. — outstanding performance recognition (November 2015)
      </p>
    </section>

    <section>
      <h2 class="font-mono text-[12.5px] uppercase tracking-[0.1em] text-[--color-text-dim] mb-5">
        Education
      </h2>
      <p class="text-[--color-text-soft] text-[14.5px] leading-relaxed">
        <strong class="text-[--color-text]"
          >Bachelors (Honors) in Computer Engineering</strong
        >, National University of Sciences and Technology (NUST). CGPA: 3.40.
        Graduated 2014.
      </p>
    </section>
  </article>
</Base>
