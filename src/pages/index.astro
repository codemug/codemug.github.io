        grid-template-columns: 1fr !important;
      }
    }
  </style>

  <script>
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const DONUT_FULL = 578.05;
    const DONUT_PCT = 0.4;

    const fmt = (val, decimals) => {
      const n = decimals > 0 ? val.toFixed(decimals) : Math.round(val).toString();
      const parts = n.split(".");
      parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ",");
      return parts.join(".");
    };

    const runCount = (el) => {
      if (el.dataset.done) return;
      el.dataset.done = "1";
      const raw = el.dataset.raw;
      if (raw && raw !== "undefined" && raw !== "") {
        el.textContent = raw;
        return;
      }
      const to = parseFloat(el.dataset.to);
      if (isNaN(to)) return;
      const decimals = parseInt(el.dataset.decimals || "0", 10);
      const prefix = el.dataset.prefix && el.dataset.prefix !== "undefined" ? el.dataset.prefix : "";
      const suffix = el.dataset.suffix && el.dataset.suffix !== "undefined" ? el.dataset.suffix : "";
      if (reduce) {
        el.textContent = prefix + fmt(to, decimals) + suffix;
        return;
      }
      const dur = 1500;
      const start = performance.now();
      const tick = (now) => {
        const t = Math.min(1, (now - start) / dur);
        const e = 1 - Math.pow(1 - t, 3);
        el.textContent = prefix + fmt(to * e, decimals) + suffix;
        if (t < 1) requestAnimationFrame(tick);
        else el.textContent = prefix + fmt(to, decimals) + suffix;
      };
      requestAnimationFrame(tick);
    };

    const fillDonut = (d) => {
      if (d.dataset.done) return;
      d.dataset.done = "1";
      const target = DONUT_FULL * (1 - DONUT_PCT);
      if (reduce) {
        d.style.transition = "none";
        d.style.strokeDashoffset = String(target);
        return;
      }
      setTimeout(() => {
        d.style.strokeDashoffset = String(target);
      }, 200);
    };

    if (reduce) {
      document.querySelectorAll("[data-reveal],[data-line]").forEach((el) => el.classList.add("in"));
      document.querySelectorAll(".count").forEach((c) => runCount(c));
      const d = document.getElementById("donut");
      if (d) fillDonut(d);
    } else {
      const groupDelays = new Map();
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((en) => {
            if (!en.isIntersecting) return;
            const el = en.target;
            const parent = el.parentElement;
            const idx = groupDelays.get(parent) || 0;
            el.style.transitionDelay = Math.min(idx * 65, 360) + "ms";
            groupDelays.set(parent, idx + 1);
            el.classList.add("in");
            el.querySelectorAll(".count").forEach((c) => setTimeout(() => runCount(c), 180));
            const d = el.querySelector("#donut");
            if (d) fillDonut(d);
            io.unobserve(el);
          });
        },
        { threshold: 0.18, rootMargin: "0px 0px -8% 0px" }
      );
      document.querySelectorAll("[data-reveal],[data-line]").forEach((el) => io.observe(el));

      // hero particle network
      const cv = document.getElementById("netcanvas");
      if (cv) {
        const ctx = cv.getContext("2d");
        let w, h, dpr, nodes;
        const N = 46;
        const setup = () => {
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          const r = cv.getBoundingClientRect();
          w = r.width;
          h = r.height || 600;
          cv.width = w * dpr;
          cv.height = h * dpr;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          if (!nodes) {
            nodes = Array.from({ length: N }, () => ({
              x: Math.random() * w,
              y: Math.random() * h,
              vx: (Math.random() - 0.5) * 0.28,
              vy: (Math.random() - 0.5) * 0.28,
              r: Math.random() * 1.6 + 0.7,
            }));
          }
        };
        setup();
        window.addEventListener("resize", setup);
        const draw = () => {
          ctx.clearRect(0, 0, w, h);
          for (const n of nodes) {
            n.x += n.vx;
            n.y += n.vy;
            if (n.x < 0 || n.x > w) n.vx *= -1;
            if (n.y < 0 || n.y > h) n.vy *= -1;
          }
          for (let i = 0; i < nodes.length; i++) {
            for (let j = i + 1; j < nodes.length; j++) {
              const a = nodes[i];
              const b = nodes[j];
              const dx = a.x - b.x;
              const dy = a.y - b.y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              if (dist < 130) {
                ctx.strokeStyle = "rgba(34,211,238," + 0.13 * (1 - dist / 130) + ")";
                ctx.lineWidth = 1;
                ctx.beginPath();
                ctx.moveTo(a.x, a.y);
                ctx.lineTo(b.x, b.y);
                ctx.stroke();
              }
            }
          }
          for (const n of nodes) {
            ctx.beginPath();
            ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
            ctx.fillStyle = "rgba(34,211,238,0.55)";
            ctx.fill();
          }
          requestAnimationFrame(draw);
        };
        draw();
      }
    }
  </script>
