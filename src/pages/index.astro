---
import Base from "../layouts/Base.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Metric from "../components/Metric.astro";
import JobRow from "../components/JobRow.astro";
import SkillGroup from "../components/SkillGroup.astro";
import WritingRow from "../components/WritingRow.astro";

const title = "Usman Shahid · Staff Site Reliability Engineer";
const description =
  "Staff SRE / Technical Lead, 11+ years scaling cloud infrastructure. Running a production AI Agent Platform at Careem with MCP, multi-agent orchestration, and HITL approval flows. Open to relocation EU/UK/IE/NL/DE.";

const metrics = [
  {
    value: "40%",
    label:
      "EKS cost reduction via Karpenter consolidation, ARM/Spot migration & custom scheduling",
  },
  {
    value: "12 → 1",
    label:
      "API gateways consolidated onto Kong at ~10k RPS, 99.99% uptime during cutover",
  },
  {
    value: "300+",
    label:
      "Microservices migrated from legacy AWS to EKS — provisioning from days to minutes",
  },
  {
    value: "~200K",
    label:
      "Daily requests on the AI Agent Platform · ~800 tools · ~60 production agents",
  },
];

const jobs = [
  {
    period: "Jan 2023 — Present",
    company: "Careem",
    role: "Staff Site Reliability Engineer",
    summary:
      "Technical Lead and SRE Architect mentoring a team focused on infrastructure provisioning and developer experience.",
    points: [
      'Designed and built a <strong class="text-[--color-text]">self-service AI Agent Platform</strong> with MCP tool-calling, multi-agent orchestration, and HITL approval flows — <strong class="text-[--color-text]">~200K req/day</strong>, <strong class="text-[--color-text]">~800 tools</strong>, <strong class="text-[--color-text]">~60 production agents</strong>.',
      'Slashed <strong class="text-[--color-text]">EKS cluster costs by 40%</strong> via Karpenter consolidation, ARM/Spot migration, VPA, and custom scheduling.',
      'Consolidated <strong class="text-[--color-text]">12 legacy API gateways (~10k RPS)</strong> onto a single Kong gateway with <strong class="text-[--color-text]">99.99% uptime</strong> during cutover.',
      "Built a fully automated provisioning platform with GitOps (Terraform + Terragrunt) — new services from days to minutes.",
    ],
  },
  {
    period: "Dec 2020 — Jan 2023",
    company: "Careem",
    role: "Senior Site Reliability Engineer",
    summary:
      "Led migration of 300+ microservices from legacy AWS infrastructure to AWS EKS.",
    points: [
      "Engineered automated provisioning of multiple EKS clusters with Terraform + Terragrunt.",
      'Built the observability stack with <strong class="text-[--color-text]">Prometheus, Thanos, and Grafana</strong> — high-cardinality storage, SLO dashboards, cost tracking.',
      "Improved deployment safety via Linkerd service mesh with automated canary rollouts through Flagger.",
    ],
  },
  {
    period: "Jul 2019 — Dec 2020",
    company: "Intech IIS",
    role: "Infrastructure Architect & Team Lead",
    summary:
      "Designed the infrastructure of a Cloud IIoT Platform while leading a team of 6 polyglot engineers in a KanBan model.",
    points: [
      'Built a bespoke <strong class="text-[--color-text]">Kubernetes Ingress Operator</strong> for bare-metal clusters using RedHat operator-sdk.',
      'Integrated <strong class="text-[--color-text]">ArgoCD with Keycloak</strong> for a secure, auditable GitOps workflow on Helm-based deployments.',
      "Implemented Google SRE golden signals on bare-metal Kubernetes using Prometheus.",
    ],
  },
  {
    period: "Jan 2017 — Jun 2019",
    company: "Intech IIS",
    role: "Senior Software / DevOps Engineer",
    summary:
      "Containerized a distributed Industrial IoT platform and built core delivery infrastructure.",
    points: [
      "Built a serverless framework in Python running code on containers via Kubernetes / Marathon / Metronome.",
      "Built an OPC → MQTT data pipeline in C# using Avro RPC and REST, plus a StatsD metric aggregator in Go.",
      "Built an OpenID Connect Identity Provider with Spring OAuth2 across AD, LDAP, JDBC, and Mongo backends.",
    ],
  },
  {
    period: "Jun 2014 — Jan 2017",
    company: "Diyatech / Alachisoft",
    role: "Software Developer — NCache & NosDB",
    summary:
      "Core developer for NCache Enterprise (distributed cache for .NET) and NosDB Enterprise (NoSQL JSON store).",
    points: [
      "Reimplemented Microsoft's Collections to prevent Large Object Heap (LOH) leakage.",
      "Built file-storage-based B+ Tree indexing with single-attribute and compound index support.",
      "Built the query execution system using Streams and nested Enumerables in C#.",
    ],
  },
];

const skills = [
  {
    cat: "SRE / Platform",
    items: [
      "SLO/SLI & error budgets",
      "Incident response",
      "On-call leadership",
      "GitOps",
      "Internal Dev Platforms",
      "FinOps",
      "Capacity planning",
    ],
  },
  {
    cat: "Kubernetes",
    items: [
      "Karpenter",
      "VPA",
      "Custom scheduling",
      "Linkerd",
      "Flagger",
      "Helm",
      "Kustomize",
      "ArgoCD",
      "operator-sdk",
    ],
  },
  {
    cat: "Cloud",
    items: [
      "AWS EKS",
      "EC2 · S3 · VPC",
      "Route 53 · IAM",
      "Bare-metal K8s",
      "Multi-cluster",
    ],
  },
  {
    cat: "Observability",
    items: ["Prometheus", "Thanos", "Grafana", "Golden signals", "SLO dashboards"],
  },
  {
    cat: "AI / LLMOps",
    items: [
      "MCP",
      "Multi-agent orchestration",
      "HITL approval flows",
      "Agent platform engineering",
    ],
  },
  {
    cat: "Languages",
    items: ["Go", "Python", "Java", "C# / .NET"],
  },
];

const posts = [
  {
    meta: "Medium · June 2025 · Tool Calling Series Pt.1",
    title: "Understanding Tool Calling and the Model Context Protocol (MCP)",
    url: "https://usmanshahid.medium.com/llm-tool-calling-series-part-1-understanding-tool-calling-and-the-model-context-protocol-mcp-911a7c422fd8",
  },
  {
    meta: "Medium · October 2025 · Tool Calling Series Pt.2",
    title: "Enabling MCP on Your Existing Microservices",
    url: "https://usmanshahid.medium.com/llm-tool-calling-series-part-2-enabling-mcp-on-your-existing-microservices-bfc9ce7dc67f",
  },
  {
    meta: "Medium · August 2020 · 4-part series",
    title:
      "Keycloak Access Control — tokens, auth flows, RBAC & Kubernetes integration",
    url: "https://medium.com/@usmanshahid",
  },
];
---

<Base title={title} description={description} path="/">
  <div class="max-w-[980px] mx-auto px-6 sm:px-8">
    <!-- HERO -->
    <header id="top" class="pt-24 sm:pt-32 pb-20 sm:pb-24">
      <div
        class="rise font-mono text-[13px] uppercase tracking-[0.16em] text-[--color-accent] mb-7"
      >
        Staff SRE · Platform Engineering · Dubai
      </div>
      <h1
        class="rise text-[clamp(46px,8vw,86px)] leading-[1.02] font-semibold tracking-[-0.035em] text-[--color-text] mb-8"
        style="animation-delay:.06s"
      >
        Usman Shahid
      </h1>
      <p
        class="rise text-[clamp(20px,2.6vw,27px)] leading-[1.5] font-[380] text-[--color-text-soft] max-w-[760px] tracking-[-0.012em]"
        style="animation-delay:.12s"
      >
        Classic SRE discipline applied to the agentic-AI era. 11+ years scaling
        resilient, cost-effective cloud infrastructure for high-traffic services —<span
          class="text-[--color-text-dim]"
        >
          now building production AI Agent platforms with MCP, multi-agent
          orchestration, and human-in-the-loop approval flows.</span
        >
      </p>
      <div
        class="rise flex flex-wrap gap-3.5 mt-11"
        style="animation-delay:.2s"
      >
        <a href="#contact" class="btn btn-primary">
          Get in touch
          <span class="text-base">→</span>
        </a>
        <a
          href="https://github.com/codemug"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-ghost">GitHub</a
        >
        <a
          href="https://linkedin.com/in/u-manshahid"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-ghost">LinkedIn</a
        >
        <a href="/cv-usman-shahid.pdf" class="btn btn-ghost">CV (PDF)</a>
      </div>
    </header>

    <!-- METRICS -->
    <section class="border-t border-[--color-hairline] py-14 sm:py-16">
      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-px bg-[--color-surface-2] border border-[--color-surface-2] rounded-2xl overflow-hidden"
      >
        {metrics.map((m) => <Metric value={m.value} label={m.label} />)}
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="work" class="py-16 sm:py-20 scroll-mt-24">
      <SectionHeading num="01" title="Experience" />
      <div class="flex flex-col">
        {
          jobs.map((j) => (
            <JobRow
              period={j.period}
              company={j.company}
              role={j.role}
              summary={j.summary}
              points={j.points}
            />
          ))
        }
      </div>
    </section>

    <!-- SKILLS -->
    <section
      id="skills"
      class="py-16 sm:py-20 border-t border-[--color-hairline] scroll-mt-24"
    >
      <SectionHeading num="02" title="Skills & Stack" />
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-14 gap-y-10"
      >
        {skills.map((g) => <SkillGroup cat={g.cat} items={g.items} />)}
      </div>
    </section>

    <!-- WRITING -->
    <section
      id="writing"
      class="py-16 sm:py-20 border-t border-[--color-hairline] scroll-mt-24"
    >
      <SectionHeading num="03" title="Selected Writing" />
      <div class="flex flex-col">
        {posts.map((p) => <WritingRow meta={p.meta} title={p.title} url={p.url} />)}
      </div>
      <p class="mt-8 text-[14px] text-[--color-text-muted]">
        <a href="/writing/">See all writing →</a>
      </p>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="py-20 sm:py-24 border-t border-[--color-hairline] scroll-mt-24">
      <div
        class="relative overflow-hidden rounded-[22px] border border-[--color-border] p-[clamp(40px,6vw,72px)] text-center"
        style="background:linear-gradient(135deg,color-mix(in oklab,var(--color-accent) 8%,var(--color-surface)),var(--color-bg))"
      >
        <div
          aria-hidden="true"
          class="pointer-events-none absolute top-[-120px] left-1/2 -translate-x-1/2 w-[600px] max-w-[120%] h-[300px]"
          style="background:radial-gradient(ellipse,color-mix(in oklab,var(--color-accent) 12%,transparent),transparent 70%)"
        >
        </div>
        <div class="relative">
          <div
            class="font-mono text-[13px] uppercase tracking-[0.12em] text-[--color-accent] mb-6"
          >
            Open to relocation · EU / UK / Ireland / NL / DE
          </div>
          <h2
            class="text-[clamp(30px,5vw,48px)] font-semibold tracking-[-0.03em] leading-[1.08] text-[--color-text] mb-6"
          >
            Let's build reliable<br />platforms together.
          </h2>
          <p
            class="text-[17px] leading-relaxed text-[--color-text-muted] max-w-[540px] mx-auto mb-9"
          >
            Senior IC roles — Staff SRE, Principal Platform Engineer, or Cloud
            Infrastructure Architect. Visa-sponsored relocation from UAE.
          </p>
          <a
            href="mailto:u.manshahid@gmail.com"
            class="btn btn-primary text-[15.5px]"
          >
            u.manshahid@gmail.com
          </a>
        </div>
      </div>
    </section>
  </div>
</Base>
