---
import Base from "../layouts/Base.astro";

const title = "Usman Shahid · Staff Site Reliability Engineer";
const description =
  "Staff SRE / Technical Lead, 11+ years scaling cloud infrastructure. Building production AI Agent platforms with MCP, multi-agent orchestration, and HITL approvals. 40% EKS cost cut, 12→1 Kong gateway consolidation at 99.99% uptime, 300+ microservices on EKS.";

// --- count-up helper: render the final value server-side (correct without JS) ---
function fmtCount(c) {
  if (c.raw) return c.raw;
  const dec = c.decimals || 0;
  const num = dec > 0 ? c.to.toFixed(dec) : Math.round(c.to).toString();
  const parts = num.split(".");
  parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ",");
  return (c.prefix || "") + parts.join(".") + (c.suffix || "");
}

const metrics = [
  { to: 11, prefix: "", suffix: "+", decimals: 0, raw: "", label: "Years scaling cloud infrastructure" },
  { to: 300, prefix: "", suffix: "+", decimals: 0, raw: "", label: "Microservices migrated to EKS" },
  { to: 0, prefix: "", suffix: "", decimals: 0, raw: "12 → 1", label: "API gateways consolidated onto Kong" },
  { to: 99.99, prefix: "", suffix: "%", decimals: 2, raw: "", label: "Uptime during gateway cutover" },
];

const primerCaps = [
  "Yielding, event-driven agents",
  "Directed cyclic graphs",
  "Workspaces & sessions",
  "Semantic search",
  "Slack · Telegram · Discord channels",
  "Built-in MCP server",
  "Human approval gates",
  "Versioned harnesses",
  "Dynamic tool & agent discovery",
];

const platformStats = [
  { to: 9, prefix: "", suffix: "", decimals: 0, raw: "", label: "Capabilities, integrated from day one" },
  { to: 3, prefix: "", suffix: "", decimals: 0, raw: "", label: "Workspace backends, local · container · k8s" },
  { to: 0, prefix: "", suffix: "", decimals: 0, raw: "Apache 2.0", label: "Open-source & self-hostable" },
];

const costLevers = [
  "Karpenter consolidation, bin-packing nodes for higher utilization.",
  "ARM (Graviton) and Spot migration for compute-heavy workloads.",
  "Vertical Pod Autoscaler right-sizing to eliminate over-provisioning.",
  "Custom scheduling to densely co-locate compatible workloads.",
];

// 12 legacy gateway nodes for the consolidation diagram
const gwCols = [50, 142, 234];
const gwRows = [56, 104, 152, 200];
const gwGrid = [];
{
  let n = 1;
  for (const y of gwRows) {
    for (const x of gwCols) {
      gwGrid.push({ x, y, cx: x + 39, ty: y + 25, label: "GW " + String(n).padStart(2, "0") });
      n++;
    }
  }
}

const gwMigration = [
  { step: "01", title: "Shadow traffic", desc: "Mirror live requests to Kong and compare responses, zero user impact." },
  { step: "02", title: "Per-route canary", desc: "Cut over one route at a time behind weighted routing." },
  { step: "03", title: "Weighted shift", desc: "Ramp traffic gradually with instant rollback on any regression." },
  { step: "04", title: "Decommission", desc: "Retire each legacy proxy once its routes are fully drained." },
];

const gwStats = [
  { to: 0, prefix: "", suffix: "", decimals: 0, raw: "12 → 1", label: "Gateways consolidated" },
  { to: 10, prefix: "~", suffix: "k", decimals: 0, raw: "", label: "Requests per second" },
  { to: 99.99, prefix: "", suffix: "%", decimals: 2, raw: "", label: "Uptime during cutover" },
  { to: 0, prefix: "", suffix: "", decimals: 0, raw: "0", label: "Requests dropped" },
];

const jobs = [
  {
    period: "Jan 2023 – Present",
    company: "Careem",
    role: "Staff Site Reliability Engineer",
    summary: "Technical Lead and SRE Architect mentoring a team focused on infrastructure provisioning and developer experience.",
    points: [
      "Designed and built a self-service AI Agent Platform with MCP tool-calling, multi-agent orchestration, and HITL approval flows, ~200K req/day, ~800 tools, ~60 production agents.",
      "Slashed EKS cluster costs by 40% via Karpenter consolidation, ARM/Spot migration, VPA, and custom scheduling.",
      "Consolidated 12 legacy API gateways (~10k RPS) onto a single Kong gateway with 99.99% uptime during cutover.",
      "Built a fully automated provisioning platform with GitOps (Terraform + Terragrunt), new services from days to minutes.",
    ],
  },
  {
    period: "Dec 2020 – Jan 2023",
    company: "Careem",
    role: "Senior Site Reliability Engineer",
    summary: "Led migration of 300+ microservices from legacy AWS infrastructure to AWS EKS.",
    points: [
      "Engineered automated provisioning of multiple EKS clusters with Terraform + Terragrunt.",
      "Built the observability stack with Prometheus, Thanos, and Grafana, high-cardinality storage, SLO dashboards, cost tracking.",
      "Improved deployment safety via Linkerd service mesh with automated canary rollouts through Flagger.",
    ],
  },
  {
    period: "Jul 2019 – Dec 2020",
    company: "Intech IIS",
    role: "Infrastructure Architect & Team Lead",
    summary: "Designed the infrastructure of a Cloud IIoT Platform while leading a team of 6 polyglot engineers in a KanBan model.",
    points: [
      "Built a bespoke Kubernetes Ingress Operator for bare-metal clusters using RedHat operator-sdk.",
      "Integrated ArgoCD with Keycloak for a secure, auditable GitOps workflow on Helm-based deployments.",
      "Implemented Google SRE golden signals on bare-metal Kubernetes using Prometheus.",
    ],
  },
  {
    period: "Jan 2017 – Jun 2019",
    company: "Intech IIS",
    role: "Senior Software / DevOps Engineer",
    summary: "Containerized a distributed Industrial IoT platform and built core delivery infrastructure.",
    points: [
      "Built a serverless framework in Python running code on containers via Kubernetes / Marathon / Metronome.",
      "Built an OPC → MQTT data pipeline in C# using Avro RPC and REST, plus a StatsD metric aggregator in Go.",
      "Built an OpenID Connect Identity Provider with Spring OAuth2 across AD, LDAP, JDBC, and Mongo backends.",
    ],
  },
  {
    period: "Jun 2014 – Jan 2017",
    company: "Diyatech / Alachisoft",
    role: "Software Developer · NCache & NosDB",
    summary: "Core developer for NCache Enterprise (distributed cache for .NET) and NosDB Enterprise (NoSQL JSON store).",
    points: [
      "Reimplemented Microsoft's Collections to prevent Large Object Heap (LOH) leakage.",
      "Built file-storage-based B+ Tree indexing with single-attribute and compound index support.",
      "Built the query execution system using Streams and nested Enumerables in C#.",
    ],
  },
];

const skills = [
  { cat: "AI / ML Ops", items: ["Primer", "Claude Code", "MCP", "vLLM", "Llama.cpp", "LLM-D", "Langchain", "Langgraph"] },
  { cat: "Observability", items: ["Prometheus", "Grafana", "Thanos", "Dynatrace", "OpenTelemetry", "Fluentbit", "Clickhouse"] },
  { cat: "Kubernetes", items: ["Helm", "Flagger", "Istio", "Karpenter", "Operator-SDK", "Linkerd", "Kong", "ArgoCD"] },
  { cat: "Cloud", items: ["Amazon Web Services", "EKS", "VPC Networking", "Bare Metal", "Multicluster"] },
  { cat: "SRE / Platform", items: ["GitOps", "FinOps", "SLIs/SLOs", "Terraform", "Terragrunt", "Incident Response"] },
  { cat: "Languages", items: ["Go", "Python", "Java", "C# / .NET"] },
];

const posts = [
  { meta: "Medium · June 2025 · Tool Calling Series Pt.1", title: "Understanding Tool Calling and the Model Context Protocol (MCP)", url: "https://usmanshahid.medium.com/llm-tool-calling-series-part-1-understanding-tool-calling-and-the-model-context-protocol-mcp-911a7c422fd8" },
  { meta: "Medium · October 2025 · Tool Calling Series Pt.2", title: "Enabling MCP on Your Existing Microservices", url: "https://usmanshahid.medium.com/llm-tool-calling-series-part-2-enabling-mcp-on-your-existing-microservices-bfc9ce7dc67f" },
  { meta: "Medium · August 2020 · 4-part series", title: "Keycloak Access Control, tokens, auth flows, RBAC & Kubernetes integration", url: "https://medium.com/@usmanshahid" },
];
---

<Base title={title} description={description} path="/">
  <div class="max-w-[1040px] mx-auto px-6 sm:px-8">
    <!-- HERO -->
    <header id="top" class="relative pt-[100px] sm:pt-[118px] pb-24 min-h-[78vh]">
      <canvas
        id="netcanvas"
        aria-hidden="true"
        class="absolute inset-x-0 top-[-40px] bottom-0 w-full h-full pointer-events-none opacity-90"></canvas>
      <div class="relative z-[2]">
        <div
          class="rise inline-flex items-center gap-2.5 font-mono text-[12.5px] uppercase tracking-[0.14em] text-[--color-accent] mb-7 rounded-full px-3.5 py-2"
          style="border:1px solid color-mix(in oklab,var(--color-accent) 28%,transparent);background:color-mix(in oklab,var(--color-accent) 5%,transparent)"
        >
          <span
            class="w-1.5 h-1.5 rounded-full bg-[--color-accent]"
            style="animation:pulse 2s ease-in-out infinite"></span>
          Staff SRE · Platform Engineering · Dubai
        </div>
        <h1
          class="rise text-[clamp(48px,8.4vw,92px)] leading-[1.0] font-semibold tracking-[-0.038em] text-[--color-text] mb-8"
          style="animation-delay:.06s"
        >
          Usman Shahid
        </h1>
        <p
          class="rise text-[clamp(20px,2.6vw,28px)] leading-[1.48] font-[380] text-[--color-text-soft] max-w-[780px] tracking-[-0.013em]"
          style="animation-delay:.12s"
        >
          Classic SRE discipline applied to the agentic-AI era. 11+ years scaling
          resilient, cost-effective cloud infrastructure,<span
            class="text-[--color-text-dim]"
          >
            now building production AI Agent platforms with MCP, multi-agent
            orchestration, and human-in-the-loop approvals.</span
          >
        </p>
        <div class="rise flex flex-wrap gap-3 mt-11" style="animation-delay:.2s">
          <a href="#contact" class="btn btn-primary"
            >Get in touch <span class="text-base">→</span></a
          >
          <a
            href="https://github.com/codemug"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost">GitHub</a
          >
          <a
            href="https://linkedin.com/in/u-manshahid"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost">LinkedIn</a
          >
        </div>
      </div>
      <div
        class="absolute bottom-7 left-0 flex items-center gap-2.5 font-mono text-[11px] tracking-[0.1em] text-[--color-text-faint] z-[2]"
      >
        <span class="w-[26px] h-px bg-[--color-border]"></span>SCROLL
      </div>
    </header>

    <!-- 01 · IMPACT METRICS -->
    <section id="impact" class="py-[70px] border-t border-[--color-hairline] scroll-mt-24">
      <div data-reveal class="flex items-baseline gap-4 mb-12">
        <span class="font-mono text-[13px] text-[--color-accent] tracking-[0.1em]">01</span>
        <h2 class="text-[clamp(26px,4vw,36px)] font-semibold tracking-[-0.025em]">Impact at a glance</h2>
      </div>
      <div
        class="stat-grid grid grid-cols-2 md:grid-cols-4 gap-px bg-[--color-surface-2] border border-[--color-surface-2] rounded-[18px] overflow-hidden"
      >
        {
          metrics.map((m) => (
            <div data-reveal class="mcell bg-[--color-surface-deep] px-6 py-9">
              <div
                class="count text-[clamp(34px,4.4vw,50px)] font-semibold tracking-[-0.035em] text-[--color-text] leading-none"
                style="font-variant-numeric:tabular-nums"
                data-to={m.to}
                data-prefix={m.prefix}
                data-suffix={m.suffix}
                data-decimals={m.decimals}
                data-raw={m.raw}
              >
                {fmtCount(m)}
              </div>
              <div class="mt-3 text-[13.5px] leading-[1.5] text-[--color-text-muted]">{m.label}</div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- 02 · PRIMER -->
    <section id="platform" class="py-20 border-t border-[--color-hairline] scroll-mt-24">
      <div data-reveal class="flex items-baseline gap-4 mb-3.5">
        <span class="font-mono text-[13px] text-[--color-accent] tracking-[0.1em]">02</span>
        <h2 class="text-[clamp(26px,4vw,36px)] font-semibold tracking-[-0.025em]">
          Primer <span class="text-[--color-text-faint] font-normal">· open-source project</span>
        </h2>
      </div>
      <p data-reveal class="text-[16px] leading-[1.6] text-[--color-text-muted] max-w-[720px] mb-7">
        An unopinionated, batteries-included agent-orchestration platform. Instead of one giant agent
        with everything crammed into its prompt, Primer orchestrates
        <span class="text-[--color-text-soft]">fleets of small, focused agents</span>, each with a
        clean working context, runnable on your own hardware.
      </p>

      <!-- core bet callout -->
      <div
        data-reveal
        class="flex gap-4 items-start rounded-xl px-6 py-5 max-w-[760px] mb-11"
        style="background:color-mix(in oklab,var(--color-accent) 4%,transparent);border:1px solid color-mix(in oklab,var(--color-accent) 25%,transparent);border-left:3px solid var(--color-accent)"
      >
        <span class="font-mono text-[11px] text-[--color-accent] tracking-[0.1em] mt-[3px] whitespace-nowrap">THE BET</span>
        <p class="text-[16px] leading-[1.6] text-[--color-text]">
          A small model given a clean, purpose-built context can rival a much larger one. A lever on
          any model, large or small.
        </p>
      </div>

      <!-- dark diagram panel (stays dark in both themes) -->
      <div
        data-reveal
        class="rounded-[22px] overflow-x-auto"
        style="background:var(--color-panel);border:1px solid #1c1c21;padding:clamp(24px,4vw,44px)"
      >
        <div class="font-mono text-[11px] tracking-[0.12em] text-[#4a4a52] uppercase mb-6">Runtime architecture</div>
        <svg viewBox="0 0 980 392" style="width:100%;min-width:720px;display:block;font-family:'Inter',sans-serif">
          <defs>
            <linearGradient id="nodeg" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#15171a"></stop><stop offset="1" stop-color="#101113"></stop>
            </linearGradient>
            <filter id="glow"><feGaussianBlur stdDeviation="3" result="b"></feGaussianBlur><feMerge><feMergeNode in="b"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge></filter>
          </defs>
          <text x="105" y="20" text-anchor="middle" fill="#4a4a52" font-size="11" font-family="JetBrains Mono" letter-spacing="1">EDGES</text>
          <text x="490" y="20" text-anchor="middle" fill="#4a4a52" font-size="11" font-family="JetBrains Mono" letter-spacing="1">ORCHESTRATION CORE</text>
          <text x="875" y="20" text-anchor="middle" fill="#4a4a52" font-size="11" font-family="JetBrains Mono" letter-spacing="1">PER-TURN</text>
          <path d="M180 56 C260 56 280 150 380 150" stroke="#22d3ee" stroke-width="1.5" fill="none" class="flowline" opacity=".75"></path>
          <path d="M180 112 C260 112 290 150 380 150" stroke="#22d3ee" stroke-width="1.5" fill="none" class="flowline" opacity=".75"></path>
          <path d="M180 168 C260 168 300 150 380 150" stroke="#22d3ee" stroke-width="1.5" fill="none" class="flowline" opacity=".75"></path>
          <path d="M180 224 C280 224 300 158 380 158" stroke="#22d3ee" stroke-width="1.5" fill="none" class="flowline" opacity=".75"></path>
          <path d="M600 130 C680 130 700 56 780 56" stroke="#22d3ee" stroke-width="1.5" fill="none" class="flowline" opacity=".7"></path>
          <path d="M600 142 C680 142 700 112 780 112" stroke="#22d3ee" stroke-width="1.5" fill="none" class="flowline" opacity=".7"></path>
          <path d="M600 158 C680 158 700 168 780 168" stroke="#22d3ee" stroke-width="1.5" fill="none" class="flowline" opacity=".7"></path>
          <path d="M600 170 C680 170 700 224 780 224" stroke="#22d3ee" stroke-width="1.5" fill="none" class="flowline" opacity=".7"></path>
          <path d="M490 196 V268" stroke="#6a6a73" stroke-width="1.4" fill="none" stroke-dasharray="5 6" opacity=".7"></path>
          <path d="M600 294 H700" stroke="#6a6a73" stroke-width="1.4" fill="none" stroke-dasharray="5 6" opacity=".7"></path>
          <g>
            <rect x="30" y="36" width="150" height="40" rx="10" fill="url(#nodeg)" stroke="#2a2c30"></rect>
            <text x="105" y="61" text-anchor="middle" fill="#ededf0" font-size="13" font-weight="600">REST · Console</text>
          </g>
          <g>
            <rect x="30" y="92" width="150" height="40" rx="10" fill="url(#nodeg)" stroke="#2a2c30"></rect>
            <text x="105" y="117" text-anchor="middle" fill="#ededf0" font-size="13" font-weight="600">MCP clients</text>
          </g>
          <g>
            <rect x="30" y="148" width="150" height="40" rx="10" fill="url(#nodeg)" stroke="#2a2c30"></rect>
            <text x="105" y="167" text-anchor="middle" fill="#ededf0" font-size="12.5" font-weight="600">Channels</text>
            <text x="105" y="180" text-anchor="middle" fill="#6a6a73" font-size="9.5">Slack · Telegram · Discord</text>
          </g>
          <g>
            <rect x="30" y="204" width="150" height="40" rx="10" fill="url(#nodeg)" stroke="#2a2c30"></rect>
            <text x="105" y="223" text-anchor="middle" fill="#ededf0" font-size="12.5" font-weight="600">Triggers</text>
            <text x="105" y="236" text-anchor="middle" fill="#6a6a73" font-size="9.5">cron · delay · webhook</text>
          </g>
          <g>
            <rect x="380" y="92" width="220" height="116" rx="14" fill="url(#nodeg)" stroke="#22d3ee" filter="url(#glow)"></rect>
            <text x="490" y="124" text-anchor="middle" fill="#22d3ee" font-size="16" font-weight="700">Worker pool</text>
            <line x1="410" y1="138" x2="570" y2="138" stroke="#1c3a40" stroke-width="1"></line>
            <text x="490" y="160" text-anchor="middle" fill="#ededf0" font-size="12.5">sessions · chats</text>
            <text x="490" y="178" text-anchor="middle" fill="#ededf0" font-size="12.5">graph runs</text>
            <text x="490" y="196" text-anchor="middle" fill="#6a6a73" font-size="10.5">directed cyclic graphs</text>
          </g>
          <g>
            <rect x="380" y="268" width="220" height="52" rx="12" fill="#101315" stroke="#1c3a40"></rect>
            <text x="490" y="291" text-anchor="middle" fill="#ededf0" font-size="13" font-weight="600">Park &amp; resume</text>
            <text x="490" y="308" text-anchor="middle" fill="#6a6a73" font-size="10.5">event-driven · frees compute while waiting</text>
          </g>
          <g>
            <rect x="700" y="268" width="180" height="52" rx="12" fill="#101315" stroke="#1c3a40"></rect>
            <text x="790" y="291" text-anchor="middle" fill="#ededf0" font-size="13" font-weight="600">Human approval</text>
            <text x="790" y="308" text-anchor="middle" fill="#6a6a73" font-size="10.5">gate the risky</text>
          </g>
          <g>
            <rect x="780" y="36" width="170" height="40" rx="10" fill="url(#nodeg)" stroke="#2a2c30"></rect>
            <text x="865" y="61" text-anchor="middle" fill="#ededf0" font-size="13" font-weight="600">LLM providers</text>
          </g>
          <g>
            <rect x="780" y="92" width="170" height="40" rx="10" fill="url(#nodeg)" stroke="#2a2c30"></rect>
            <text x="865" y="117" text-anchor="middle" fill="#ededf0" font-size="13" font-weight="600">Tools · MCP</text>
          </g>
          <g>
            <rect x="780" y="148" width="170" height="40" rx="10" fill="url(#nodeg)" stroke="#2a2c30"></rect>
            <text x="865" y="167" text-anchor="middle" fill="#ededf0" font-size="12.5" font-weight="600">Workspaces</text>
            <text x="865" y="180" text-anchor="middle" fill="#6a6a73" font-size="9.5">local · container · k8s</text>
          </g>
          <g>
            <rect x="780" y="204" width="170" height="40" rx="10" fill="url(#nodeg)" stroke="#2a2c30"></rect>
            <text x="865" y="223" text-anchor="middle" fill="#ededf0" font-size="12.5" font-weight="600">Collections</text>
            <text x="865" y="236" text-anchor="middle" fill="#6a6a73" font-size="9.5">semantic search</text>
          </g>
          <g>
            <rect x="380" y="344" width="220" height="34" rx="9" fill="#0e1418" stroke="#1c3a40"></rect>
            <text x="490" y="366" text-anchor="middle" fill="#22d3ee" font-size="12" font-weight="600" font-family="JetBrains Mono">Postgres + pgvector</text>
          </g>
          <path d="M490 320 V344" stroke="#1c3a40" stroke-width="1.4" fill="none"></path>
        </svg>

        <div class="flex flex-wrap gap-2.5 mt-9">
          {primerCaps.map((c) => <span class="chip-d">{c}</span>)}
        </div>

        <div
          class="grid grid-cols-3 gap-px rounded-[14px] overflow-hidden mt-8"
          style="background:#1a1a1f;border:1px solid #1a1a1f"
        >
          {
            platformStats.map((s) => (
              <div style="background:#0d0d0f;padding:24px 22px">
                <div
                  class="count text-[clamp(26px,3vw,34px)] font-semibold tracking-[-0.03em] text-[--color-accent] leading-none"
                  style="font-variant-numeric:tabular-nums"
                  data-to={s.to}
                  data-prefix={s.prefix}
                  data-suffix={s.suffix}
                  data-decimals={s.decimals}
                  data-raw={s.raw}
                >
                  {fmtCount(s)}
                </div>
                <div class="mt-2.5 text-[12.5px] text-[#9a9aa3]">{s.label}</div>
              </div>
            ))
          }
        </div>

        <a
          href="https://github.com/primerhq/primer"
          target="_blank"
          rel="noopener noreferrer"
          class="prim-link inline-flex items-center gap-2.5 mt-7 text-[14px] text-[--color-accent] font-medium"
          >View Primer on GitHub <span>→</span></a
        >
      </div>
    </section>

    <!-- 03 · COST DONUT -->
    <section class="py-20 border-t border-[--color-hairline]">
      <div data-reveal class="flex items-baseline gap-4 mb-11">
        <span class="font-mono text-[13px] text-[--color-accent] tracking-[0.1em]">03</span>
        <h2 class="text-[clamp(26px,4vw,36px)] font-semibold tracking-[-0.025em]">Engineering for cost</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-[280px_1fr] gap-12 items-center">
        <div data-reveal class="flex justify-center">
          <svg width="240" height="240" viewBox="0 0 240 240">
            <circle cx="120" cy="120" r="92" fill="none" stroke="var(--color-surface-2)" stroke-width="20"></circle>
            <circle
              id="donut"
              cx="120"
              cy="120"
              r="92"
              fill="none"
              stroke="var(--color-accent)"
              stroke-width="20"
              stroke-linecap="round"
              transform="rotate(-90 120 120)"
              stroke-dasharray="578.05"
              stroke-dashoffset="578.05"
              class="ring-prog"
              style="filter:drop-shadow(0 0 8px color-mix(in oklab,var(--color-accent) 40%,transparent))"></circle>
            <text
              x="120"
              y="116"
              text-anchor="middle"
              fill="var(--color-text)"
              font-size="46"
              font-weight="700"
              font-family="Inter"
              letter-spacing="-2"
              class="count"
              data-to="40"
              data-suffix="%"
              data-decimals="0"
              data-prefix=""
