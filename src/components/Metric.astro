---
interface Props {
  value: string;
  label: string;
}
const { value, label } = Astro.props;
---

<div
  class="rounded-lg border border-[--color-border] bg-[--color-surface] px-3 py-3 text-center"
>
  <div class="text-lg sm:text-xl font-semibold text-[--color-text] leading-tight font-mono">
    {value}
  </div>
  <div
    class="text-[10px] sm:text-xs text-[--color-text-muted] leading-tight mt-1 uppercase tracking-wider"
  >
    {label}
  </div>
</div>
