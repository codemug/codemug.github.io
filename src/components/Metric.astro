---
interface Props {
  value: string;
  label: string;
}
const { value, label } = Astro.props;
---

<div
  class="bg-[--color-surface-deep] px-6 py-8 sm:px-7 transition-colors hover:bg-[--color-surface]"
>
  <div
    class="text-[clamp(30px,4vw,44px)] font-semibold tracking-[-0.03em] text-[--color-text] leading-none"
  >
    {value}
  </div>
  <div class="mt-3 text-[13.5px] leading-relaxed text-[--color-text-muted]">
    {label}
  </div>
</div>
