---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
}
const { id, eyebrow, title } = Astro.props;
---

<header class="mb-8" id={id}>
  {
    eyebrow && (
      <p class="text-xs font-mono uppercase tracking-[0.18em] text-[--color-accent] mb-2">
        {eyebrow}
      </p>
    )
  }
  <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-[--color-text]">
    {title}
  </h2>
</header>
