---
interface Props {
  id?: string;
  num?: string;
  eyebrow?: string;
  title: string;
}
const { id, num, eyebrow, title } = Astro.props;
---

{
  num ? (
    <header class="flex items-baseline gap-4 mb-12 sm:mb-14" id={id}>
      <span class="font-mono text-[13px] text-[--color-accent] tracking-[0.1em]">
        {num}
      </span>
      <h2 class="text-[clamp(28px,4vw,38px)] font-semibold tracking-[-0.025em] text-[--color-text]">
        {title}
      </h2>
    </header>
  ) : (
    <header class="mb-10" id={id}>
      {eyebrow && (
        <p class="font-mono text-[13px] uppercase tracking-[0.16em] text-[--color-accent] mb-3">
          {eyebrow}
        </p>
      )}
      <h2 class="text-[clamp(28px,4vw,38px)] font-semibold tracking-[-0.025em] text-[--color-text]">
        {title}
      </h2>
    </header>
  )
}
