---
interface Props {
  meta: string;
  title: string;
  url: string;
  external?: boolean;
}
const { meta, title, url, external = true } = Astro.props;
const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
const arrow = external ? "↗" : "→";
---

<a
  href={url}
  target={target}
  rel={rel}
  class="group grid grid-cols-[1fr_auto] gap-6 items-center py-6 border-t border-[--color-hairline] transition-[padding] duration-200 hover:pl-3"
>
  <div>
    <div
      class="font-mono text-[12px] tracking-[0.04em] text-[--color-text-dim] mb-2"
    >
      {meta}
    </div>
    <h3
      class="text-[19px] font-medium tracking-[-0.01em] leading-snug text-[--color-text] max-w-[680px]"
    >
      {title}
    </h3>
  </div>
  <span
    class="text-[22px] text-[--color-text-dim] transition-all duration-200 group-hover:text-[--color-accent] group-hover:translate-x-1"
    aria-hidden="true">{arrow}</span
  >
</a>
