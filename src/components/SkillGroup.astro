---
interface Props {
  cat: string;
  items: string[];
}
const { cat, items } = Astro.props;
---

<div>
  <h3
    class="font-mono text-[12.5px] tracking-[0.08em] uppercase text-[--color-text-dim] mb-4"
  >
    {cat}
  </h3>
  <div class="flex flex-wrap gap-2.5">
    {
      items.map((t) => (
        <span class="text-[13.5px] text-[--color-text-soft] bg-[--color-surface] border border-[--color-border] px-3.5 py-2 rounded-lg transition-colors hover:border-[--color-accent] hover:text-[--color-text]">
          {t}
        </span>
      ))
    }
  </div>
</div>
