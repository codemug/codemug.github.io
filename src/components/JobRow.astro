---
interface Props {
  period: string;
  company: string;
  role: string;
  summary: string;
  points: string[];
}
const { period, company, role, summary, points } = Astro.props;
---

<div
  class="grid grid-cols-1 sm:grid-cols-[172px_1fr] gap-3 sm:gap-9 py-8 border-t border-[--color-hairline]"
>
  <div>
    <div class="font-mono text-[12.5px] tracking-[0.02em] text-[--color-text-dim]">
      {period}
    </div>
    <div class="mt-2 text-[14px] font-medium text-[--color-text-muted]">
      {company}
    </div>
  </div>
  <div>
    <h3 class="text-[20px] font-semibold tracking-[-0.01em] text-[--color-text] mb-2">
      {role}
    </h3>
    <p class="text-[15px] leading-relaxed text-[--color-text-muted] mb-4 max-w-[600px]">
      {summary}
    </p>
    <ul class="flex flex-col gap-3 list-none">
      {
        points.map((p) => (
          <li class="flex gap-3 text-[14.5px] leading-snug text-[--color-text-soft] max-w-[640px]">
            <span class="flex-none mt-[7px] w-[5px] h-[5px] rounded-full bg-[--color-accent]" />
            <span set:html={p} />
          </li>
        ))
      }
    </ul>
  </div>
</div>
