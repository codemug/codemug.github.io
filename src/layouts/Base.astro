---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = "/" } = Astro.props;
const siteUrl = "https://codemug.github.io";
const canonical = new URL(path, siteUrl).toString();
const ogImage = new URL("/og-image.png", siteUrl).toString();

const navLinks = [
  { label: "Impact", href: "/#impact", hideSmall: true },
  { label: "Platform", href: "/#platform", hideSmall: true },
  { label: "Work", href: "/#work", hideSmall: false },
  { label: "Contact", href: "/#contact", hideSmall: false },
];

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Usman Shahid",
  givenName: "Usman",
  familyName: "Shahid",
  jobTitle: "Staff Site Reliability Engineer",
  url: siteUrl,
  email: "mailto:u.manshahid@gmail.com",
  image: ogImage,
  worksFor: {
    "@type": "Organization",
    name: "Careem",
    url: "https://careem.com",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "National University of Sciences and Technology (NUST)",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Dubai",
    addressCountry: "AE",
  },
  knowsAbout: [
    "Site Reliability Engineering",
    "Kubernetes",
    "Karpenter",
    "AWS EKS",
    "Kong API Gateway",
    "Prometheus",
    "Thanos",
    "Grafana",
    "Terraform",
    "ArgoCD",
    "GitOps",
    "Model Context Protocol",
    "Multi-Agent Orchestration",
    "Human-in-the-Loop Systems",
    "Go",
    "Python",
    "Java",
    "C#",
  ],
  sameAs: [
    "https://linkedin.com/in/u-manshahid",
    "https://github.com/codemug",
    "https://medium.com/@usmanshahid",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0b" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Usman Shahid" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link
      rel="preload"
      href="/fonts/InterVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/JetBrainsMono.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Usman Shahid" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Usman Shahid · Staff Site Reliability Engineer" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline>
      // Apply theme BEFORE first paint to avoid flash.
      (function () {
        try {
          var saved = localStorage.getItem("theme");
          var theme =
            saved ||
            (window.matchMedia("(prefers-color-scheme: light)").matches
              ? "light"
              : "dark");
          if (theme === "light") {
            document.documentElement.setAttribute("data-theme", "light");
          }
        } catch (e) {
          /* ignore */
        }
      })();
    </script>

    <script
      type="application/ld+json"
      set:html={JSON.stringify(personJsonLd)}
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- fixed ambient field -->
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 z-0"
      style="background:radial-gradient(900px 480px at 50% -8%,color-mix(in oklab,var(--color-accent) 7%,transparent),transparent 70%),radial-gradient(700px 500px at 90% 30%,color-mix(in oklab,var(--color-accent) 3.5%,transparent),transparent 70%)"
    >
    </div>

    <header
      class="sticky top-0 z-50 border-b border-[--color-hairline-2] backdrop-blur-md"
      style="background:color-mix(in oklab,var(--color-bg) 70%,transparent)"
    >
      <nav
        class="max-w-[1040px] mx-auto px-6 sm:px-8 py-4 flex items-center justify-between"
      >
        <a
          href="/"
          class="flex items-center gap-3 font-mono text-[13px] tracking-[0.01em]"
        >
          <span
            class="inline-block w-[9px] h-[9px] rounded-full bg-[--color-accent] shadow-[0_0_12px_var(--color-accent)]"
            style="animation:pulse 2.4s ease-in-out infinite"></span>
          <span class="text-[--color-text] font-medium"
            >codemug<span class="text-[--color-text-dim]">.github.io</span></span
          >
        </a>
        <div
          class="flex items-center gap-4 sm:gap-7 text-[13.5px] text-[--color-text-muted]"
        >
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  "transition-colors hover:text-[--color-text]",
                  link.hideSmall && "hidden sm:inline",
                ]}
              >
                {link.label}
              </a>
            ))
          }
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle color theme"
            title="Toggle color theme"
            class="ml-0.5 inline-flex items-center justify-center w-8 h-8 rounded-md border border-[--color-border] text-[--color-text-muted] hover:text-[--color-text] hover:border-[--color-border-strong] hover:bg-[--color-surface] transition-colors"
          >
            <svg
              class="w-4 h-4 hidden dark-show"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4"></circle>
              <path
                d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
              ></path>
            </svg>
            <svg
              class="w-4 h-4 hidden light-show"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <main class="flex-1 relative z-10">
      <slot />
    </main>

    <footer
      class="relative z-10 border-t border-[--color-hairline] text-[13.5px] text-[--color-text-dim]"
    >
      <div
        class="max-w-[1040px] mx-auto px-6 sm:px-8 py-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
      >
        <span class="font-mono">codemug.github.io · Dubai, UAE · GMT+4</span>
        <div class="flex flex-wrap gap-6">
          <a
            href="https://github.com/codemug"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-[--color-text]">GitHub</a
          >
          <a
            href="https://linkedin.com/in/u-manshahid"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-[--color-text]">LinkedIn</a
          >
          <a
            href="https://medium.com/@usmanshahid"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-[--color-text]">Medium</a
          >
        </div>
      </div>
    </footer>

    <style is:global>
      /* Show the correct icon for the active theme */
      html:not([data-theme="light"]) .dark-show {
        display: inline-block;
      }
      html[data-theme="light"] .light-show {
        display: inline-block;
      }
    </style>

    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var isLight =
            document.documentElement.getAttribute("data-theme") === "light";
          if (isLight) {
            document.documentElement.removeAttribute("data-theme");
            localStorage.setItem("theme", "dark");
          } else {
            document.documentElement.setAttribute("data-theme", "light");
            localStorage.setItem("theme", "light");
          }
        });
      })();
    </script>
  </body>
</html>
