---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = "/" } = Astro.props;
const siteUrl = "https://codemug.github.io";
const canonical = new URL(path, siteUrl).toString();
const ogImage = new URL("/og-image.png", siteUrl).toString();

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Usman Shahid",
  givenName: "Usman",
  familyName: "Shahid",
  jobTitle: "Staff Site Reliability Engineer",
  url: siteUrl,
  email: "mailto:u.manshahid@gmail.com",
  image: ogImage,
  worksFor: {
    "@type": "Organization",
    name: "Careem",
    url: "https://careem.com",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "National University of Sciences and Technology (NUST)",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Dubai",
    addressCountry: "AE",
  },
  knowsAbout: [
    "Site Reliability Engineering",
    "Kubernetes",
    "Karpenter",
    "AWS EKS",
    "Kong API Gateway",
    "Prometheus",
    "Thanos",
    "Grafana",
    "Terraform",
    "ArgoCD",
    "GitOps",
    "Model Context Protocol",
    "Multi-Agent Orchestration",
    "Human-in-the-Loop Systems",
    "Go",
    "Python",
    "Java",
    "C#",
  ],
  sameAs: [
    "https://linkedin.com/in/u-manshahid",
    "https://github.com/codemug",
    "https://medium.com/@usmanshahid",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0b" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Usman Shahid" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link
      rel="preload"
      href="/fonts/InterVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Usman Shahid" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Usman Shahid · Staff Site Reliability Engineer" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline>
      // Apply theme BEFORE first paint to avoid flash.
      (function () {
        try {
          var saved = localStorage.getItem("theme");
          var theme =
            saved ||
            (window.matchMedia("(prefers-color-scheme: light)").matches
              ? "light"
              : "dark");
          if (theme === "light") {
            document.documentElement.setAttribute("data-theme", "light");
          }
        } catch (e) {
          /* ignore */
        }
      })();
    </script>

    <script
      type="application/ld+json"
      set:html={JSON.stringify(personJsonLd)}
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <header
      class="border-b border-[--color-border] bg-[--color-bg]/80 backdrop-blur-sm sticky top-0 z-10"
    >
      <nav
        class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between text-sm"
      >
        <a
          href="/"
          class="font-semibold text-[--color-text] hover:no-underline tracking-tight"
        >
          Usman Shahid
        </a>
        <div class="flex items-center gap-3 sm:gap-6 text-[--color-text-muted]">
          <a href="/" class="hover:text-[--color-text]">Home</a>
          <a href="/cv/" class="hover:text-[--color-text]">CV</a>
          <a href="/writing/" class="hover:text-[--color-text]">Writing</a>
          <a href="/uses/" class="hover:text-[--color-text]">Uses</a>
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle color theme"
            title="Toggle color theme"
            class="ml-1 inline-flex items-center justify-center w-8 h-8 rounded-md border border-[--color-border] hover:border-[--color-border-strong] hover:bg-[--color-surface] transition-colors"
          >
            <svg
              class="w-4 h-4 hidden dark-show"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4"></circle>
              <path
                d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
              ></path>
            </svg>
            <svg
              class="w-4 h-4 hidden light-show"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer
      class="border-t border-[--color-border] mt-24 py-10 text-sm text-[--color-text-dim]"
    >
      <div
        class="max-w-3xl mx-auto px-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3"
      >
        <p>
          Built with <a
            href="https://astro.build"
            target="_blank"
            rel="noopener noreferrer">Astro</a
          > · Source on <a
            href="https://github.com/codemug/codemug.github.io"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
        </p>
        <p>&copy; 2026 Usman Shahid</p>
      </div>
    </footer>

    <style is:global>
      /* Show the correct icon for the active theme */
      html:not([data-theme="light"]) .dark-show {
        display: inline-block;
      }
      html[data-theme="light"] .light-show {
        display: inline-block;
      }
    </style>

    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var isLight =
            document.documentElement.getAttribute("data-theme") === "light";
          if (isLight) {
            document.documentElement.removeAttribute("data-theme");
            localStorage.setItem("theme", "dark");
          } else {
            document.documentElement.setAttribute("data-theme", "light");
            localStorage.setItem("theme", "light");
          }
        });
      })();
    </script>
  </body>
</html>
